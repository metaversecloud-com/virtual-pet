# .gitignore

# Ignore node_modules directory
node_modules/

# Ignore environment configuration files
.env
.env.local
.env.development
.env.production
.env-k12

# Ignore build artifacts and logs
dist/
build/
*.log

# Ignore IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak

# Ignore OS-generated files
.DS_Store
Thumbs.db
